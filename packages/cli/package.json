{
  "name": "@get-cauldron/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for the Cauldron AI-powered software development platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "cauldron": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "cauldron": "tsx src/cli.ts",
    "dev": "tsx watch src/index.ts",
    "serve:engine": "tsx src/engine-server.ts"
  },
  "dependencies": {
    "@get-cauldron/engine": "workspace:*",
    "@get-cauldron/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@trpc/client": "11.15.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.1",
    "eventsource": "^4.1.0",
    "hono": "^4.12.9",
    "inngest": "^4.1.0",
    "ioredis": "^5.10.1",
    "ollama": "^0.6.3",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
