{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "TEST_DATABASE_URL",
    "REDIS_URL",
    "INNGEST_DEV",
    "HOLDOUT_ENCRYPTION_KEY",
    "MISTRAL_API_KEY",
    "ANTHROPIC_API_KEY",
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "OLLAMA_HOST",
    "CAULDRON_API_KEY",
    "GITHUB_WEBHOOK_SECRET",
    "CAULDRON_PROJECT_ROOT",
    "LOG_LEVEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:wiring": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "db:generate": { "cache": false },
    "db:migrate": { "cache": false },
    "db:seed": {
      "dependsOn": ["db:migrate"],
      "cache": false
    },
    "lint": {}
  }
}
